{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-module" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-module" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label for="input-name" class="col-sm-2 col-form-label">{{ entry_name }}</label>
            <div class="col-sm-10">
              <input type="text" name="name" value="{{ name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control"/>
              <div id="error-name" class="invalid-feedback"></div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-status" class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="status" value="0"/>
                <input type="checkbox" name="status" value="1" id="input-status" class="form-check-input"{% if status %} checked{% endif %}/>
              </div>
            </div>
          </div>
          
          <div class="table-responsive">
            <table id="category-item" class="table table-striped table-bordered table-hover">
              <thead>
                <tr>
                  <td class="text-start">{{ entry_category }}</td>
                  <td class="text-start">{{ entry_title }}</td>
                  <td class="text-center">{{ entry_image }}</td>
                  <td class="text-end">{{ entry_sort_order }}</td>
                  <td></td>
                </tr>
              </thead>
              <tbody>
                {% set item_row = 0 %}
                {% for category_item in category_items %}
                  <tr id="category-item-row-{{ item_row }}">
                    <td class="text-start">
                      <input type="text" name="category_items[{{ item_row }}][name]" value="{{ category_item.name }}" placeholder="{{ entry_category }}" id="input-category-{{ item_row }}" data-oc-target="autocomplete-category-{{ item_row }}" class="form-control" autocomplete="off"/>
                      <input type="hidden" name="category_items[{{ item_row }}][category_id]" value="{{ category_item.category_id }}" id="input-category-id-{{ item_row }}"/>
                      <ul id="autocomplete-category-{{ item_row }}" class="dropdown-menu"></ul>
                    </td>
                    <td class="text-start">
                      {% for language in languages %}
                        <div class="input-group">
                          <span class="input-group-text"><img src="{{ language.image }}" title="{{ language.name }}"/></span>
                          <input type="text" name="category_items[{{ item_row }}][custom_title][{{ language.language_id }}]" value="{{ category_item.custom_title[language.language_id] }}" placeholder="{{ entry_title }}" class="form-control"/>
                        </div>
                      {% endfor %}
                    </td>
                    <td class="text-center">
                      <div class="card image">
                        <img src="{{ category_item.thumb }}" alt="" title="" id="thumb-image-{{ item_row }}" data-oc-placeholder="{{ placeholder }}" class="card-img-top"/>
                        <input type="hidden" name="category_items[{{ item_row }}][custom_image]" value="{{ category_item.custom_image }}" id="input-image-{{ item_row }}"/>
                        <div class="card-body">
                          <button type="button" data-oc-toggle="image" data-oc-target="#input-image-{{ item_row }}" data-oc-thumb="#thumb-image-{{ item_row }}" class="btn btn-primary btn-sm btn-block"><i class="fa-solid fa-pencil"></i> {{ button_edit }}</button>
                          <button type="button" data-oc-toggle="clear" data-oc-target="#input-image-{{ item_row }}" data-oc-thumb="#thumb-image-{{ item_row }}" class="btn btn-warning btn-sm btn-block"><i class="fa-regular fa-trash-can"></i> {{ button_clear }}</button>
                        </div>
                      </div>
                    </td>
                    <td class="text-end">
                      <input type="text" name="category_items[{{ item_row }}][sort_order]" value="{{ category_item.sort_order }}" placeholder="{{ entry_sort_order }}" class="form-control"/>
                    </td>
                    <td class="text-end"><button type="button" onclick="$('#category-item-row-{{ item_row }}').remove();" data-bs-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa-solid fa-minus-circle"></i></button></td>
                  </tr>
                  {% set item_row = item_row + 1 %}
                {% endfor %}
              </tbody>
              <tfoot>
                <tr>
                  <td colspan="4"></td>
                  <td class="text-end"><button type="button" onclick="addItem();" data-bs-toggle="tooltip" title="{{ button_item_add }}" class="btn btn-primary"><i class="fa-solid fa-plus-circle"></i></button></td>
                </tr>
              </tfoot>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
var item_row = {{ item_row }};

function addItem() {
	var html  = '<tr id="category-item-row-' + item_row + '">';
	html += '  <td class="text-start">';
    html += '    <input type="text" name="category_items[' + item_row + '][name]" value="" placeholder="{{ entry_category|escape('js') }}" id="input-category-' + item_row + '" data-oc-target="autocomplete-category-' + item_row + '" class="form-control" autocomplete="off"/>';
    html += '    <input type="hidden" name="category_items[' + item_row + '][category_id]" value="" id="input-category-id-' + item_row + '"/>';
    html += '    <ul id="autocomplete-category-' + item_row + '" class="dropdown-menu"></ul>';
    html += '  </td>';
	html += '  <td class="text-start">';
    {% for language in languages %}
    html += '    <div class="input-group">';
    html += '      <span class="input-group-text"><img src="{{ language.image }}" title="{{ language.name }}"/></span>';
    html += '      <input type="text" name="category_items[' + item_row + '][custom_title][{{ language.language_id }}]" value="" placeholder="{{ entry_title|escape('js') }}" class="form-control"/>';
    html += '    </div>';
    {% endfor %}
    html += '  </td>';
	html += '  <td class="text-center">';
    html += '    <div class="card image">';
    html += '      <img src="{{ placeholder }}" alt="" title="" id="thumb-image-' + item_row + '" data-oc-placeholder="{{ placeholder }}" class="card-img-top"/>';
    html += '      <input type="hidden" name="category_items[' + item_row + '][custom_image]" value="" id="input-image-' + item_row + '"/>';
    html += '      <div class="card-body">';
    html += '        <button type="button" data-oc-toggle="image" data-oc-target="#input-image-' + item_row + '" data-oc-thumb="#thumb-image-' + item_row + '" class="btn btn-primary btn-sm btn-block"><i class="fa-solid fa-pencil"></i> {{ button_edit|escape('js') }}</button>';
    html += '        <button type="button" data-oc-toggle="clear" data-oc-target="#input-image-' + item_row + '" data-oc-thumb="#thumb-image-' + item_row + '" class="btn btn-warning btn-sm btn-block"><i class="fa-regular fa-trash-can"></i> {{ button_clear|escape('js') }}</button>';
    html += '      </div>';
    html += '    </div>';
    html += '  </td>';
	html += '  <td class="text-end"><input type="text" name="category_items[' + item_row + '][sort_order]" value="" placeholder="{{ entry_sort_order|escape('js') }}" class="form-control"/></td>';
	html += '  <td class="text-end"><button type="button" onclick="$(\'#category-item-row-' + item_row + '\').remove();" data-bs-toggle="tooltip" title="{{ button_remove|escape('js') }}" class="btn btn-danger"><i class="fa-solid fa-minus-circle"></i></button></td>';
	html += '</tr>';

	$('#category-item tbody').append(html);

    addAutocomplete(item_row);

	item_row++;
}

function addAutocomplete(row) {
    $('#input-category-' + row).autocomplete({
        source: function(request, response) {
            $.ajax({
                url: 'index.php?route=extension/dc_minimal/module/category_entry.autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
                dataType: 'json',
                success: function(json) {
                    response($.map(json, function(item) {
                        return {
                            label: item['name'],
                            value: item['category_id']
                        }
                    }));
                }
            });
        },
        select: function(item) {
            $('#input-category-' + row).val(item['label']);
            $('#input-category-id-' + row).val(item['value']);
        }
    });
}

// Initialize existing
$(document).ready(function() {
    $('[id^=input-category-]').each(function() {
        var element_id = $(this).attr('id');
        var row_id = element_id.replace('input-category-', '');
        addAutocomplete(row_id);
    });
});
//--></script>
{{ footer }}
