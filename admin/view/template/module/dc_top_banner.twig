    html += '      <div class="card-body p-2">';
    html += '        <button type="button" data-oc-toggle="image" data-oc-target="#input-image-' + banner_row + '" data-oc-thumb="#thumb-image-' + banner_row + '" class="btn btn-primary btn-sm w-100 mb-1"><i class="fa-solid fa-pencil"></i></button>';
    html += '        <button type="button" data-oc-toggle="clear" data-oc-target="#input-image-' + banner_row + '" data-oc-thumb="#thumb-image-' + banner_row + '" class="btn btn-warning btn-sm w-100"><i class="fa-solid fa-trash-can"></i></button>';
    html += '      </div>';
    html += '    </div>';
    html += '  </td>';
    html += '  <td class="text-start"><input type="text" name="banners[' + banner_row + '][link]" value="" placeholder="{{ entry_link }}" class="form-control"/></td>';
    html += '  <td class="text-start"><input type="text" name="banners[' + banner_row + '][button]" value="" placeholder="{{ entry_button }}" class="form-control"/></td>';
    html += '  <td class="text-end"><button type="button" onclick="$(\'#banner-row-' + banner_row + '\').remove();" data-bs-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa-solid fa-minus-circle"></i></button></td>';
