    html += '  </td>';
	html += '  <td class="text-end"><button type="button" onclick="$(\'#service-row-' + service_row  + '\').remove();" data-bs-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa-solid fa-minus-circle"></i></button></td>';
