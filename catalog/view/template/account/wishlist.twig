{{ header }}
<div id="account-wishlist" class="container py-4" style="font-family: 'Inter', sans-serif;">
  <ul class="breadcrumb bg-transparent p-0 mb-4" style="font-size: 0.9rem;">
    {% for breadcrumb in breadcrumbs %}
      <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}" class="text-decoration-none text-muted">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  
  <div class="row">
    {{ column_left }}
    <div id="content" class="col-lg-9 col-12">
      {{ content_top }}
      
      <div class="mb-4 pb-3 border-bottom d-flex align-items-center">
        <h2 class="mb-0 fw-bold" style="color: #005baa;"><i class="fa-solid fa-heart text-danger me-2"></i> {{ heading_title }}</h2>
      </div>
      
      <div id="wishlist" class="mb-5">
        {{ list }}
      </div>
      
      <div class="d-flex justify-content-end mb-5">
        <a href="{{ continue }}" class="btn rounded-pill px-5 py-3 fw-bold" style="background-color: #c49a45; color: white; transition: all 0.3s; box-shadow: 0 4px 6px rgba(196,154,69,0.2);">
          {{ button_continue }} <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
      </div>
      
      {{ content_bottom }}
    </div>
    
    {{ column_right }}
  </div>
</div>

<script type="text/javascript"><!--
$('#wishlist').on('click', '.btn-remove-wishlist', function(e) {
    e.preventDefault();

    var element = this;

    $.ajax({
        url: $(element).attr('href'),
        dataType: 'json',
        beforeSend: function() {
            $(element).prop('disabled', true).html('<i class="fa-solid fa-circle-notch fa-spin"></i>');
        },
        complete: function() {
            $(element).prop('disabled', false);
        },
        success: function(json) {
            if (json['error']) {
                if (typeof showModalMessage === 'function') {
                    showModalMessage('danger', json['error']);
                } else {
                    alert(json['error']);
                }
            }

            if (json['success']) {
                if (typeof showModalMessage === 'function') {
                    showModalMessage('success', json['success']);
                }
                
                var customer_token = getURLVar('customer_token');
                var url = 'index.php?route=account/wishlist.list&language={{ language }}';
                if (customer_token) {
                    url += '&customer_token=' + customer_token;
                }
                
                $('#wishlist').load(url);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
    });
});
//--></script>
{{ footer }}
