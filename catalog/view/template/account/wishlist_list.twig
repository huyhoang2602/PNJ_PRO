{% if products %}
  <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; overflow: hidden;">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0" style="min-width: 800px;">
        <thead style="background-color: #f8f9fa;">
          <tr>
            <th class="py-3 px-4 text-center text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px; width: 120px;">{{ column_image }}</th>
            <th class="py-3 px-4 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px;">{{ column_name }}</th>
            <th class="py-3 px-4 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px;">{{ column_model }}</th>
            <th class="py-3 px-4 text-center text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px;">{{ column_stock }}</th>
            <th class="py-3 px-4 text-end text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px;">{{ column_price }}</th>
            <th class="py-3 px-4 text-end text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 700; letter-spacing: 0.5px; width: 160px;">{{ column_action }}</th>
          </tr>
        </thead>
        <tbody class="border-top-0">
          {% set product_row = 0 %}
          {% for product in products %}
            <tr id="product-row-{{ product_row }}">
              <td class="text-center px-4 py-4">
                {% if product.thumb %}
                  <a href="{{ product.href }}">
                      <img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-fluid rounded shadow-sm border" style="max-height: 80px; transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
                  </a>
                {% endif %}
              </td>
              <td class="px-4 py-4">
                  <a href="{{ product.href }}" class="fw-bold text-dark text-decoration-none fs-6 mb-1 d-block hover-gold">{{ product.name }}</a>
                  <form id="form-product-{{ product_row }}" action="{{ cart_add }}" method="post" data-oc-toggle="ajax" data-oc-load="{{ cart }}" data-oc-target="#cart">
                      <input type="hidden" name="product_id" value="{{ product.product_id }}"/>
                      <input type="hidden" name="quantity" value="{{ product.minimum }}"/>
                  </form>
              </td>
              <td class="px-4 py-4 text-muted fw-medium fs-6">{{ product.model }}</td>
              <td class="text-center px-4 py-4 fw-medium fs-6 {% if product.stock == 'In Stock' or product.stock == 'Còn hàng' %}text-success{% else %}text-muted{% endif %}">{{ product.stock }}</td>
              <td class="text-end px-4 py-4">
                {% if product.price %}
                  {% if not product.special %}
                      <span class="fw-bold text-dark fs-6">{{ product.price }}</span>
                  {% else %}
                      <div class="fw-bold text-danger fs-6">{{ product.special }}</div>
                      <div class="text-muted text-decoration-line-through small">{{ product.price }}</div>
                  {% endif %}
                {% endif %}
              </td>
              <td class="text-end px-4 py-4">
                <div class="d-flex flex-column gap-2 align-items-end">
                  <button type="submit" form="form-product-{{ product_row }}" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold shadow-sm" style="transition: all 0.2s; min-width: 130px;"><i class="fa-solid fa-cart-plus me-1"></i> Mua ngay</button>
                  <a href="{{ product.remove }}" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold shadow-sm btn-remove-wishlist" style="transition: all 0.2s; min-width: 130px;"><i class="fa-solid fa-trash-can me-1"></i> Xóa</a>
                </div>
              </td>
            </tr>
            {% set product_row = product_row + 1 %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  
  <style>
  .hover-gold:hover { color: #c49a45 !important; }
  .btn-outline-primary:hover { transform: translateY(-1px); }
  .btn-outline-danger:hover { transform: translateY(-1px); }
  </style>

{% else %}
  <div class="card border-0 shadow-sm text-center py-5 mb-5" style="border-radius: 12px; background-color: #fcfcfc;">
    <div class="card-body py-5">
        <div class="mb-4 text-muted" style="opacity: 0.3;"><i class="fa-solid fa-heart-crack fa-5x"></i></div>
        <h4 class="fw-bold mb-3 text-dark">{{ text_no_results }}</h4>
        <p class="text-muted mb-4">Danh sách sản phẩm yêu thích của bạn đang trống. Hãy quay lại cửa hàng để khám phá nhé!</p>
        <a href="{{ continue }}" class="btn rounded-pill px-5 py-3 fw-bold shadow-sm" style="background-color: #c49a45; color: white; transition: all 0.3s;">
            Tiếp tục mua sắm <i class="fa-solid fa-arrow-right ms-2"></i>
        </a>
    </div>
  </div>
{% endif %}
