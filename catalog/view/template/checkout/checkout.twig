{{ header }}
<div id="checkout-checkout" class="container crystal-checkout-page pb-5">
  <ul class="breadcrumb mb-5">
    {% for breadcrumb in breadcrumbs %}
      <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
    {% endfor %}
  </ul>
  
  <div class="row">
    {{ column_left }}
    <div id="content" class="col">
      {{ content_top }}
      
      <div class="checkout-header mb-5">
        <h1 class="text-center">{{ heading_title }}</h1>
      </div>

      <div class="row g-5">
        {% if register or payment_address or shipping_address %}
          <div class="col-lg-8">
            <div id="checkout-main-forms">
                {% if register %}
                  <div id="checkout-register" class="checkout-card mb-4">{{ register }}</div>
                {% endif %}
                {% if payment_address %}
                  <div id="checkout-payment-address" class="checkout-card mb-4">{{ payment_address }}</div>
                {% endif %}
                {% if shipping_address %}
                  <div id="checkout-shipping-address" class="checkout-card mb-4">{{ shipping_address }}</div>
                {% endif %}
                
                {% if shipping_method %}
                  <div id="checkout-shipping-method" class="checkout-card mb-4">
                      {{ shipping_method }}
                  </div>
                {% endif %}
                
                <div id="checkout-payment-method" class="checkout-card mb-4">
                    {{ payment_method }}
                </div>

                <!-- Integrated Review & Payment Details -->
                <div id="checkout-confirm" class="checkout-card mb-5 border-top pt-4">
                    {{ confirm }}
                </div>
            </div>
          </div>
        {% endif %}
        
        <div class="col-lg-4">
          <div class="checkout-summary-sticky sticky-top" style="top: 100px;">
              <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: white; border: 1px solid #eee !important;">
                <div class="card-body p-4">
                  <h5 class="text-uppercase small mb-4 fw-bold text-dark" style="letter-spacing: 2px; border-left: 3px solid #c9a441; padding-left: 10px;">{{ text_summary ?: 'Order Summary' }}</h5>
                  
                  <div id="checkout-sidebar-products" class="mb-3 overflow-auto" style="max-height: 300px;">
                    <!-- Sync from confirm.twig -->
                    <div class="text-center py-4 text-muted small opacity-50">
                        <i class="fa-solid fa-cart-shopping fs-2 mb-2 d-block"></i>
                        Select methods to see items
                    </div>
                  </div>
                  
                  <div id="checkout-sidebar-totals" class="pt-3 border-top">
                    <!-- Sync from confirm.twig -->
                  </div>
                </div>
              </div>
              
              <div class="trust-badges p-3 border-0 rounded-4 text-center bg-white shadow-sm small text-muted">
                <div class="mb-2"><i class="fa-solid fa-shield-halved text-success me-2"></i> 100% Secure Checkout</div>
                <div><i class="fa-solid fa-truck-fast text-primary me-2"></i> Fast & Reliable Delivery</div>
              </div>
          </div>
        </div>
      </div>
      
      {{ content_bottom }}
    </div>
    {{ column_right }}
  </div>
</div>
{{ footer }}
