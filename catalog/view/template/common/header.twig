<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <!-- DC MINIMAL THEME OVERRIDE ACTIVE -->
    <meta name="theme-dc-minimal" content="active">

    <title>{{ title }}</title>
    <base href="{{ base }}" />

    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
    {% if keywords %}<meta name="keywords" content="{{ keywords }}" />{% endif %}

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <script src="extension/dc_minimal/catalog/view/javascript/jquery.js"></script>
    <link href="extension/dc_minimal/catalog/view/bootstrap/css/bootstrap.min.css" rel="stylesheet" media="screen" />
    <script src="extension/dc_minimal/catalog/view/bootstrap/js/popper.js" type="text/javascript"></script>
    <script src="extension/dc_minimal/catalog/view/bootstrap/js/bootstrap.min.js" type="text/javascript"></script>
    <script src="extension/dc_minimal/catalog/view/javascript/theme.js" type="text/javascript"></script>
    <script src="extension/dc_minimal/catalog/view/javascript/dc_minimal.js" type="text/javascript"></script>
    
    <link href="extension/dc_minimal/catalog/view/fontawesome/css/all.min.css" rel="stylesheet" type="text/css" />
    <link href="extension/dc_minimal/catalog/view/stylesheet/stylesheet.css" rel="stylesheet">
    <link href="extension/dc_minimal/catalog/view/stylesheet/header.css" rel="stylesheet">
    <link href="extension/dc_minimal/catalog/view/stylesheet/home.css" rel="stylesheet">
    <link href="extension/dc_minimal/catalog/view/stylesheet/dc_theme.css" rel="stylesheet">

    <link rel="icon" href="{{ icon }}">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js" type="text/javascript"></script>

    {% for style in styles %}
    <link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}" />
    {% endfor %}
    
    {% for script in scripts %}
    <script src="{{ script.href }}" type="text/javascript"></script>
    {% endfor %}
    
    {% for link in links %}
    <link href="{{ link.href }}" rel="{{ link.rel }}" />
    {% endfor %}

    {% if analytics is iterable %}
        {% for analytic in analytics %}
            {{ analytic }}
        {% endfor %}
    {% else %}
        {{ analytics }}
    {% endif %}
</head>

<body class="{{ class }}">
{{ top_banner }}
<div id="alert" class="toast-container position-fixed top-0 end-0 p-3"></div>

<header class="pnj-header">
    <div class="pnj-top">
        <div class="pnj-container pnj-flex">
            <!-- Mobile Toggle -->
            <div class="pnj-mobile-toggle d-lg-none">
                <i class="fa fa-bars"></i>
            </div>

            <div class="pnj-top-left d-none d-lg-flex">
                <a href="#"><i class="fa fa-book"></i> Câu Chuyện PNJ</a>
                <a href="#"><i class="fa fa-users"></i> Quan Hệ Cổ Đông (IR)</a>
                <a href="#"><i class="fa fa-map-marker"></i> Cửa Hàng</a>
                <a href="#"><i class="fa fa-briefcase"></i> Tuyển dụng</a>
            </div>

            <div class="pnj-logo-center">
                <a href="{{ home }}">
                    <img src="{{ logo ?: base ~ 'image/catalog/demo/logopnj.png' }}" alt="{{ name }}">
                </a>
            </div>

            <div class="pnj-top-right">
                {{ language }}
                
                <span class="hotline d-none d-md-inline">
                    <i class="fa fa-headphones"></i> {{ dc_hotline ? dc_hotline : '1800 54 54 57' }}
                </span>

                <div class="pnj-tools">
                    {% if logged %}
                        <a href="{{ account }}"><i class="fa fa-user"></i> <span class="d-none d-sm-inline">Tài khoản</span></a>
                    {% else %}
                        <a href="{{ login }}"><i class="fa fa-user"></i> <span class="d-none d-sm-inline">Đăng nhập</span></a>
                    {% endif %}

                    <a href="{{ shopping_cart }}" class="cart-link">
                        <i class="fa fa-shopping-bag"></i> <span class="d-none d-sm-inline">Giỏ hàng</span>
                        <span class="cart-badge">{{ cart_count }}</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="pnj-divider d-none d-lg-block"></div>

    <div class="pnj-bottom">
        <div class="pnj-container pnj-bottom-flex">
            {{ mega_menu }}
        </div>
    </div>
</header>

<!-- PREMIUM CRYSTAL SEARCH MODAL -->
<div id="pnj-search-modal" class="pnj-search-modal">
    <div class="pnj-search-modal-overlay"></div>
    <div class="pnj-search-modal-content">
        <div class="pnj-search-modal-header">
            <div class="pnj-search-modal-input-wrapper">
                <i class="fa fa-search"></i>
                <input type="text" placeholder="Tìm kiếm nhanh" id="pnj-search-modal-input">
                <i class="fa fa-times pnj-close-search"></i>
            </div>
        </div>
        
        <div class="pnj-search-modal-body" id="pnj-search-modal-body">
            <div class="search-discovery-content">
                <!-- 1. OFFERS -->
                <div class="search-section search-promotions">
                    <div class="section-title"><i class="fa fa-gift"></i> Ưu đãi online tháng 3 <span class="badge-discount">Ưu đãi đến 20%</span></div>
                </div>

                <!-- 2. TRENDS -->
                <div class="search-section">
                    <div class="section-title"><i class="fa fa-line-chart"></i> Top tìm kiếm</div>
                    <div class="tag-list">
                        {% if search_categories %}
                            {% for cat in search_categories %}
                                <a href="{{ cat.href }}" class="search-tag">{{ cat.name }}</a>
                            {% endfor %}
                        {% else %}
                            <a href="#" class="search-tag">Nhẫn cưới</a>
                            <a href="#" class="search-tag">Hàng mới</a>
                            <a href="#" class="search-tag">Trang sức Kim cương</a>
                        {% endif %}
                    </div>
                </div>

                <div class="search-section">
                    <div class="section-title"><i class="fa fa-bolt"></i> Dịch vụ hot</div>
                    <div class="tag-list">
                        <span class="search-tag">Trả góp 0%</span>
                        <span class="search-tag">Giao hàng 3h</span>
                        <span class="search-tag">Ưu đãi thêm 800k</span>
                    </div>
                </div>

                <!-- 3. BRANDS -->
                <div class="search-section">
                    <div class="section-title"><i class="fa fa-star"></i> Thương hiệu nổi bật</div>
                    <div class="brand-grid">
                        {% for brand in brands %}
                            {% set brand_name_up = brand.name|upper %}
                            {% if 'PNJ' in brand_name_up or 'MANCODE' in brand_name_up or 'STYLE' in brand_name_up or 'DISNEY' in brand_name_up %}
                                <a href="{{ brand.href }}" class="search-brand-item">
                                    <img src="{{ brand.thumb }}" alt="{{ brand.name }}">
                                </a>
                            {% endif %}
                        {% endfor %}
                        <!-- If some are specifically needed and not in catalog yet, add as interactive but with warning if # -->
                        {# <a href="#" class="search-brand-item">PNJ</a> #}
                    </div>
                </div>
            </div>

            <!-- 4. POPULAR PRODUCTS / SEARCH RESULTS -->
            <div class="search-section" id="pnj-search-results-section">
                <div class="section-title" id="pnj-search-results-title"><i class="fa fa-search"></i> Sản phẩm được tìm nhiều</div>
                <div class="search-product-grid" id="pnj-search-results-grid">
                    {% if search_products %}
                        {% for product in search_products %}
                            <a href="{{ product.href }}" class="search-product-item">
                                <img src="{{ product.thumb }}" alt="{{ product.name }}" class="product-thumb">
                                <div class="product-info">{{ product.name }}</div>
                            </a>
                        {% endfor %}
                    {% else %}
                        <!-- Fallback if no products found -->
                        <a href="#" class="search-product-item">
                            <div class="product-thumb"></div>
                            <div class="product-info">Nhẫn cưới Kim cương</div>
                        </a>
                        <a href="#" class="search-product-item">
                            <div class="product-thumb"></div>
                            <div class="product-info">Dây chuyền vàng 10K</div>
                        </a>
                        <a href="#" class="search-product-item">
                            <div class="product-thumb"></div>
                            <div class="product-info">Bông tai vàng 18K</div>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
    // Mega Menu Interaction
    const items = document.querySelectorAll(".mega-item");
    items.forEach(item => {
        item.addEventListener("click", function() {
            const parentModal = this.closest(".mega-modal");
            parentModal.querySelectorAll(".mega-item").forEach(i => i.classList.remove("active"));
            this.classList.add("active");
            const target = this.getAttribute("data-target");
            if (!target) return;
            parentModal.querySelectorAll(".mega-content").forEach(content => content.classList.remove("active"));
            const targetEl = parentModal.querySelector("#" + target);
            if (targetEl) targetEl.classList.add("active");
        });
    });

    // Mobile Menu Toggle
    const mobileToggle = document.querySelector(".pnj-mobile-toggle");
    const navContainer = document.getElementById("pnj-nav-container");
    const navClose = document.querySelector(".pnj-nav-close");

    if (mobileToggle && navContainer) {
        mobileToggle.addEventListener("click", function() {
            navContainer.classList.add("active");
        });
    }

    if (navClose && navContainer) {
        navClose.addEventListener("click", function() {
            navContainer.classList.remove("active");
        });
    }

    // Search Modal Toggle
    const searchInput = document.querySelector(".pnj-search input");
    const searchModal = document.getElementById("pnj-search-modal");
    const searchModalInput = document.getElementById("pnj-search-modal-input");
    const closeSearch = document.querySelector(".pnj-close-search");
    const searchOverlay = document.querySelector(".pnj-search-modal-overlay");

    if (searchInput && searchModal) {
        searchInput.addEventListener("click", function(e) {
            e.preventDefault();
            searchModal.classList.add("active");
            if (searchModalInput) {
                setTimeout(() => {
                    searchModalInput.focus();
                }, 100);
            }
        });
    }

    const closeModal = function() {
        if (searchModal) searchModal.classList.remove("active");
    };

    if (closeSearch) closeSearch.addEventListener("click", closeModal);
    if (searchOverlay) searchOverlay.addEventListener("click", closeModal);

    // Close on ESC key
    document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") closeModal();
    });

    // --- LIVE SEARCH LOGIC ---
    const searchModalBody = document.querySelector("#pnj-search-modal-body");
    const searchResultGrid = document.querySelector("#pnj-search-results-grid");
    const searchSectionTitle = document.querySelector("#pnj-search-results-title");
    
    // Store original product lists (Popular Products)
    let originalProductsHTML = "";
    if (searchResultGrid) originalProductsHTML = searchResultGrid.innerHTML;

    if (searchModalInput && searchResultGrid) {
        let searchTimeout = null;

        searchModalInput.addEventListener("input", function() {
            const query = this.value.trim();
            
            if (searchTimeout) clearTimeout(searchTimeout);

            if (query.length < 2) {
                // Restore original list if query too short
                searchResultGrid.innerHTML = originalProductsHTML;
                if (searchSectionTitle) searchSectionTitle.innerHTML = '<i class="fa fa-search"></i> Sản phẩm được tìm nhiều';
                if (searchModalBody) searchModalBody.classList.remove("is-searching");
                return;
            }

            // Setting loading state or just wait
            searchTimeout = setTimeout(function() {
                if (searchModalBody) searchModalBody.classList.add("is-searching");
                fetch('index.php?route=extension/dc_minimal/module/search.autocomplete&filter_name=' + encodeURIComponent(query))
                    .then(response => response.json())
                    .then(data => {
                        if (searchSectionTitle) searchSectionTitle.innerHTML = '<i class="fa fa-search"></i> Kết quả tìm kiếm cho "' + query + '"';
                        
                        if (data.length > 0) {
                            let html = '';
                            data.forEach(product => {
                                html += `
                                    <a href="${product.href}" class="search-product-item">
                                        <img src="${product.thumb}" alt="${product.name}" class="product-thumb">
                                        <div class="product-info">${product.name}</div>
                                    </a>
                                `;
                            });
                            searchResultGrid.innerHTML = html;
                        } else {
                            searchResultGrid.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 20px; color: #999;">Không tìm thấy sản phẩm phù hợp.</div>';
                        }
                    })
                    .catch(error => {
                        console.error('Search error:', error);
                    });
            }, 300); // 300ms debounce
        });
    }
});
</script>