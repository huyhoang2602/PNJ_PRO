{% if brands %}
<section class="dc-brand-section">

    <div class="dc-title-wrapper">
            <img 
                src="https://cdn.pnj.io/images/2026/homepage-theme/XTT/title_thuong_hieu_noi_bat.png"
                alt="Bạn đang tìm gì hôm nay?"
                class="dc-title-img">
        </div>
    <div class="dc-brand-slider">
        <button class="dc-nav dc-prev">&#10094;</button>

        <div class="dc-brand-track">
        
          {% for brand in brands %}
              <div class="dc-brand-slide">
                  <a href="{{ brand.href }}">
                      <img src="{{ brand.thumb }}" alt="{{ brand.name }}">
                      <div class="dc-brand-logo">{{ brand.name }}</div>
                  </a>
              </div>
          {% endfor %}
      </div>

        <button class="dc-nav dc-next">&#10095;</button>
    </div>

    <div class="dc-dots">
        {% for brand in brands %}
            <span class="dc-dot {% if loop.index == 2 %}active{% endif %}"></span>
        {% endfor %}
    </div>

</section>
{% endif %}
<script>
document.addEventListener("DOMContentLoaded", function () {

    const track = document.querySelector(".dc-brand-track");
    const slides = Array.from(document.querySelectorAll(".dc-brand-slide"));
    const nextBtn = document.querySelector(".dc-next");
    const prevBtn = document.querySelector(".dc-prev");

    const visibleCount = 3; // số item hiển thị cùng lúc
    let index = visibleCount;
    let interval;

    const slideWidth = slides[0].offsetWidth + 30;

    // Clone đủ số lượng visible
    const prependClones = slides.slice(-visibleCount).map(slide => slide.cloneNode(true));
    const appendClones = slides.slice(0, visibleCount).map(slide => slide.cloneNode(true));

    prependClones.forEach(clone => track.prepend(clone));
    appendClones.forEach(clone => track.append(clone));

    const allSlides = document.querySelectorAll(".dc-brand-slide");

    track.style.transform = `translateX(-${slideWidth * index}px)`;

    function moveSlide() {
        track.style.transition = "transform 0.5s ease";
        track.style.transform = `translateX(-${slideWidth * index}px)`;
    }

    function nextSlide() {
        index++;
        moveSlide();
    }

    function prevSlide() {
        index--;
        moveSlide();
    }

    track.addEventListener("transitionend", () => {
        if (index >= allSlides.length - visibleCount) {
            track.style.transition = "none";
            index = visibleCount;
            track.style.transform = `translateX(-${slideWidth * index}px)`;
        }

        if (index <= 0) {
            track.style.transition = "none";
            index = allSlides.length - (visibleCount * 2);
            track.style.transform = `translateX(-${slideWidth * index}px)`;
        }
    });

    function startAuto() {
        interval = setInterval(nextSlide, 3000);
    }

    function stopAuto() {
        clearInterval(interval);
    }

    nextBtn.addEventListener("click", () => {
        nextSlide();
        stopAuto();
        startAuto();
    });

    prevBtn.addEventListener("click", () => {
        prevSlide();
        stopAuto();
        startAuto();
    });

    startAuto();
});
</script>