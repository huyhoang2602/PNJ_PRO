{{ header }}
<link rel="stylesheet" href="extension/dc_minimal/catalog/view/stylesheet/error.css">

<div id="error-not-found" class="error-page-wrapper">
    <div class="error-content">
        <!-- Background Code decoration -->
        <div class="error-code">404</div>
        
        <div class="error-foreground">
            <div class="error-icon">
                <i class="fa fa-gem"></i>
            </div>
            
            <h1 class="error-title">{{ text_error_not_found_title }}</h1>
            
            <p class="error-message">
                {{ text_error_not_found_message }}
            </p>
            
            <div class="error-actions">
                <a href="{{ continue }}" class="btn-premium btn-premium-primary">
                    <i class="fa fa-home"></i> {{ button_continue ?: text_return_home }}
                </a>
                <a href="{{ home ?: 'index.php?route=common/home' }}" class="btn-premium btn-premium-outline">
                    <i class="fa fa-search"></i> {{ text_discover_products }}
                </a>
            </div>
        </div>
    </div>
</div>

<style>
/* Inline fallback if CSS fails to load for some reason, or to handle specific PNJ-blue colors */
:root {
    --pnj-blue: #003468;
}
</style>

{{ footer }}
