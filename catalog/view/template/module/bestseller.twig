{% set module = random(1000000) %}

<section class="dc-bestseller-products my-5">
  <div class="container">
    <div class="text-center brand-title">
        <h3 class="mb-4">{{ heading_title }}</h3>
    </div>
    <div class="dc-featured-wrapper bg-white shadow-sm p-4 rounded-4 position-relative" style="background: linear-gradient(108deg, #e3f2ff 0%, #ffffff 50%, #e3f2ff 100%);">
      <div id="bestseller-carousel-{{ module }}" class="owl-carousel product-carousel">
        {% for product in products %}
          <div class="item">
            {{ product }}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script type="text/javascript">
$(document).ready(function() {
    $('#bestseller-carousel-{{ module }}').owlCarousel({
        loop: false,
        margin: 20,
        nav: true,
        dots: false,
        navText: [
            '<span class="carousel-nav-btn prev" style="left: -20px;"><i class="fa-solid fa-chevron-left"></i></span>',
            '<span class="carousel-nav-btn next" style="right: -20px;"><i class="fa-solid fa-chevron-right"></i></span>'
        ],
        autoplay: false,
        responsive: {
            0: { items: 2, margin: 10 },
            576: { items: 2 },
            768: { items: 3 },
            1200: { items: 4 }
        }
    });
});
</script>
