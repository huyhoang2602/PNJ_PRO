<div class="brand-section container my-5">

    <div class="text-center brand-title">
        <h3>{{ heading_title }}Thương hiệu nổi bật</h3>
    </div>

    <div id="brand-owl-carousel" class="owl-carousel">

        {% for manufacturer in manufacturers %}
        <div class="brand-item">
            <a href="{{ manufacturer.href }}">

                <div class="brand-card">

                    <div class="brand-image">
                        <img src="{{ manufacturer.image }}" alt="{{ manufacturer.name }}">
                    </div>

                    <div class="brand-logo">
                        <img src="{{ manufacturer.image }}" alt="{{ manufacturer.name }}">
                    </div>

                </div>

            </a>
        </div>
        {% endfor %}

    </div>

</div>

<script type="text/javascript">
    $(document).ready(function () {
        $('#brand-owl-carousel').owlCarousel({
            loop: true,
            margin: 20,
            nav: true,
            dots: true,
            autoplay: true,
            navText: [
                '<button class="btn btn-light rounded-circle position-absolute top-50 start-0 translate-middle-y shadow-sm" style="z-index:10; left: -10px !important;"><i class="fa fa-chevron-left"></i></button>',
                '<button class="btn btn-light rounded-circle position-absolute top-50 end-0 translate-middle-y shadow-sm" style="z-index:10; right: -10px !important;"><i class="fa fa-chevron-right"></i></button>'
            ],
            responsive: {
                0: { items: 1 },
                600: { items: 2 },
                1000: { items: 3 }
            }
        });
    });
</script>