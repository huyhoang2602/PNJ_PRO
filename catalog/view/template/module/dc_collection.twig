{% set module_id = uid %}

<div id="dc-collection-{{ module_id }}" class="dc-collection-section">
    <div class="container text-center collection-header">
        <h2 class="section-title">{{ title }}</h2>
    </div>

    <div class="collection-banners-shell">
        <div class="collection-banners-container">
            <button type="button" class="swiper-button-prev banner-prev-{{ module_id }} banner-nav-btn"></button>

            <div class="swiper collection-banners-swiper-{{ module_id }}">
                <div class="swiper-wrapper">
                    {% set render_times = collections|length < 6 ? 4 : (collections|length < 8 ? 2 : 1) %}
                    {% for i in 1..render_times %}
                        {% for key, collection in collections %}
                            <div class="swiper-slide" data-original-index="{{ key }}">
                                <div class="collection-banner-card">
                                    <img
                                        src="{{ collection.image }}"
                                        alt="{{ collection.title }}"
                                        title="{{ collection.title }}"
                                        class="img-fluid w-100 h-100"
                                    />
                                </div>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>

            <button type="button" class="swiper-button-next banner-next-{{ module_id }} banner-nav-btn"></button>
        </div>

        <div class="collection-custom-pagination banner-pagination-{{ module_id }}">
            {% for key, collection in collections %}
                <span class="custom-dot {% if key == 0 %}active{% endif %}" data-index="{{ key }}"></span>
            {% endfor %}
        </div>
    </div>

    <div class="container-fluid collection-products-container px-lg-5">
        {% for key, collection in collections %}
            <div
                class="collection-products-wrapper-{{ module_id }} {% if key != 0 %}d-none{% endif %}"
                id="collection-products-{{ module_id }}-{{ key }}"
            >
                <div class="swiper collection-products-swiper-{{ module_id }}-{{ key }}">
                    <div class="swiper-wrapper">
                        {% for product in collection.products %}
                            <div class="swiper-slide h-auto">
                                <div class="product-card-pnj h-100">
                                    <div class="image-wrapper">
                                        <a href="{{ product.href }}">
                                            <img
                                                src="{{ product.thumb }}"
                                                alt="{{ product.name }}"
                                                title="{{ product.name }}"
                                                class="img-fluid"
                                            />
                                        </a>
                                    </div>

                                    <div class="product-details">
                                        <h6 class="product-name-pnj">
                                            <a href="{{ product.href }}" class="text-decoration-none">
                                                {{ product.name }}
                                            </a>
                                        </h6>

                                        {% if product.price %}
                                            <div class="price-pnj">
                                                {% if not product.special %}
                                                    <span class="price-current">{{ product.price }}</span>
                                                {% else %}
                                                    <div class="price-special-wrap">
                                                        <span class="price-old">{{ product.price }}</span>
                                                        <span class="price-current price-special">{{ product.special }}</span>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="swiper-button-prev product-prev-{{ module_id }}"></div>
                    <div class="swiper-button-next product-next-{{ module_id }}"></div>
                </div>

                {% if collection.link %}
                    <div class="text-center collection-more-wrap">
                        <a href="{{ collection.link }}" class="collection-more-btn">
                            Xem thêm
                        </a>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<style>
#dc-collection-{{ module_id }}.dc-collection-section {
    overflow: hidden;
    background: transparent;
    padding: 42px 0 52px;
}

#dc-collection-{{ module_id }} .collection-header {
    margin-bottom: 18px;
}

#dc-collection-{{ module_id }} .section-title {
    margin: 0 auto;
    color: #0b3b75;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    text-align: center !important;
    display: block;
    width: 100%;
}

#dc-collection-{{ module_id }} .collection-banners-shell {
    position: relative;
    max-width: 1320px;
    margin: 0 auto 34px;
    padding: 0 72px;
}

#dc-collection-{{ module_id }} .collection-banners-container {
    position: relative;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} {
    overflow: visible !important;
    padding: 20px 0 16px !important;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-wrapper {
    align-items: center;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide {
    width: 250px;
    opacity: 0.35;
    transition: opacity 0.45s ease;
    pointer-events: none;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide-prev,
#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide-next {
    opacity: 0.78;
    z-index: 2;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide-active {
    opacity: 1;
    z-index: 5;
    pointer-events: auto;
}

#dc-collection-{{ module_id }} .collection-banner-card {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: #ffffff;
    border: 3px solid transparent;
    box-shadow: none;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
}

#dc-collection-{{ module_id }} .collection-banner-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

#dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide-active .collection-banner-card {
    border-color: #003468;
    box-shadow: 0 15px 35px rgba(0, 52, 104, 0.2);
}

#dc-collection-{{ module_id }} .banner-nav-btn {
    width: 34px !important;
    height: 34px !important;
    top: 50% !important;
    margin-top: 0 !important;
    transform: translateY(-50%);
    border: 0;
    border-radius: 50%;
    background: #e6e6e6;
    color: #666666;
    box-shadow: none;
}

#dc-collection-{{ module_id }} .banner-nav-btn:hover {
    background: #dbdbdb;
    color: #333333;
}

#dc-collection-{{ module_id }} .banner-nav-btn::after {
    font-size: 13px !important;
    font-weight: 700;
}

#dc-collection-{{ module_id }} .banner-prev-{{ module_id }} {
    left: -65px;
}

#dc-collection-{{ module_id }} .banner-next-{{ module_id }} {
    right: -65px;
}

#dc-collection-{{ module_id }} .collection-custom-pagination {
    margin-top: 15px;
    display: flex;
    justify-content: center;
    gap: 8px;
}

#dc-collection-{{ module_id }} .collection-custom-pagination .custom-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c9c9c9;
    cursor: pointer;
    transition: all 0.25s ease;
}

#dc-collection-{{ module_id }} .collection-custom-pagination .custom-dot.active {
    background: #0b4c97;
    width: 24px;
    border-radius: 4px;
}

#dc-collection-{{ module_id }} .collection-products-container {
    margin-top: 10px;
}

#dc-collection-{{ module_id }} .product-card-pnj {
    background: #f7f7f7;
    border-radius: 18px;
    padding: 14px;
    text-align: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
}

#dc-collection-{{ module_id }} .product-card-pnj:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
    background: #ffffff;
}

#dc-collection-{{ module_id }} .image-wrapper {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    padding: 16px;
    margin-bottom: 14px;
}

#dc-collection-{{ module_id }} .image-wrapper img {
    display: block;
    width: 100%;
    transition: transform 0.45s ease;
}

#dc-collection-{{ module_id }} .product-card-pnj:hover .image-wrapper img {
    transform: scale(1.06);
}

#dc-collection-{{ module_id }} .product-details {
    padding: 0 6px;
}

#dc-collection-{{ module_id }} .product-name-pnj {
    margin: 0 0 10px;
    min-height: 44px;
    font-size: 0.95rem;
    line-height: 1.45;
    font-weight: 500;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

#dc-collection-{{ module_id }} .product-name-pnj a {
    color: #1d2b3a;
}

#dc-collection-{{ module_id }} .product-name-pnj a:hover {
    color: #0b4c97;
}

#dc-collection-{{ module_id }} .price-pnj {
    min-height: 28px;
}

#dc-collection-{{ module_id }} .price-current {
    font-size: 1.05rem;
    font-weight: 700;
    color: #9e1c21;
}

#dc-collection-{{ module_id }} .price-old {
    font-size: 0.82rem;
    color: #8a8a8a;
    text-decoration: line-through;
    margin-bottom: 2px;
    display: inline-block;
}

#dc-collection-{{ module_id }} .price-special-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
}

#dc-collection-{{ module_id }} .collection-more-wrap {
    margin-top: 28px;
}

#dc-collection-{{ module_id }} .collection-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 150px;
    padding: 10px 26px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #eceff3;
    color: #233142;
    transition: all 0.25s ease;
}

#dc-collection-{{ module_id }} .collection-more-btn:hover {
    background: #0b4c97;
    color: #ffffff;
}

#dc-collection-{{ module_id }} .product-prev-{{ module_id }},
#dc-collection-{{ module_id }} .product-next-{{ module_id }} {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #ffffff;
    color: #0b4c97;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12);
}

#dc-collection-{{ module_id }} .product-prev-{{ module_id }}::after,
#dc-collection-{{ module_id }} .product-next-{{ module_id }}::after {
    font-size: 14px;
    font-weight: 700;
}

@media (min-width: 768px) {
    #dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide {
        width: 300px;
    }

    #dc-collection-{{ module_id }} .section-title {
        font-size: 2.2rem;
    }
}

@media (min-width: 1200px) {
    #dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide {
        width: 330px;
    }
}

@media (max-width: 991.98px) {
    #dc-collection-{{ module_id }} .collection-banners-shell {
        padding: 0 24px;
    }

    #dc-collection-{{ module_id }} .banner-prev-{{ module_id }},
    #dc-collection-{{ module_id }} .banner-next-{{ module_id }} {
        display: none;
    }
}

@media (max-width: 575.98px) {
    #dc-collection-{{ module_id }}.dc-collection-section {
        padding: 32px 0 40px;
    }

    #dc-collection-{{ module_id }} .section-title {
        font-size: 1.65rem;
    }

    #dc-collection-{{ module_id }} .collection-banners-shell {
        padding: 0 10px;
        margin-bottom: 24px;
    }

    #dc-collection-{{ module_id }} .collection-banners-swiper-{{ module_id }} .swiper-slide {
        width: 220px;
    }
}
</style>

<script type="text/javascript">
$(document).ready(function () {
    const mainContainer = $('#dc-collection-{{ module_id }}');
    const productSwipers = {};

    function syncProducts(originalIndex) {
        if (originalIndex === undefined || originalIndex === null) return;

        mainContainer.find('.collection-products-wrapper-{{ module_id }}').addClass('d-none');
        const $target = mainContainer.find('#collection-products-{{ module_id }}-' + originalIndex);

        if ($target.length) {
            $target.removeClass('d-none');
            setTimeout(function () {
                const swiperInstance = productSwipers[originalIndex];
                if (swiperInstance) {
                    swiperInstance.update();
                }
            }, 60);
        }
    }

    {% for key, collection in collections %}
        productSwipers[{{ key }}] = new Swiper('.collection-products-swiper-{{ module_id }}-{{ key }}', {
            slidesPerView: 1,
            spaceBetween: 20,
            speed: 500,
            grabCursor: true,
            navigation: {
                nextEl: '#collection-products-{{ module_id }}-{{ key }} .product-next-{{ module_id }}',
                prevEl: '#collection-products-{{ module_id }}-{{ key }} .product-prev-{{ module_id }}'
            },
            breakpoints: {
                576: {
                    slidesPerView: 2,
                    spaceBetween: 20
                },
                992: {
                    slidesPerView: 3,
                    spaceBetween: 24
                },
                1200: {
                    slidesPerView: 4,
                    spaceBetween: 24
                }
            }
        });
    {% endfor %}

    const totalCollections = {{ collections|length }};

    const bannerSwiper = new Swiper('.collection-banners-swiper-{{ module_id }}', {
        effect: 'coverflow',
        centeredSlides: true,
        slidesPerView: 'auto',
        loop: true,
        grabCursor: true,
        simulateTouch: true,
        watchSlidesProgress: true,
        speed: 650,
        allowTouchMove: true,
        coverflowEffect: {
            rotate: 0,
            stretch: -80,
            depth: 120,
            modifier: 1,
            scale: 0.85,
            slideShadows: false
        },
        navigation: {
            nextEl: '.banner-next-{{ module_id }}',
            prevEl: '.banner-prev-{{ module_id }}'
        },
        on: {
            init: function () {
                const originalIndex = this.realIndex % totalCollections;
                syncProducts(originalIndex);
                
                mainContainer.find('.collection-custom-pagination .custom-dot').removeClass('active');
                mainContainer.find('.collection-custom-pagination .custom-dot[data-index="' + originalIndex + '"]').addClass('active');
            },
            slideChange: function () {
                const originalIndex = this.realIndex % totalCollections;
                syncProducts(originalIndex);

                mainContainer.find('.collection-custom-pagination .custom-dot').removeClass('active');
                mainContainer.find('.collection-custom-pagination .custom-dot[data-index="' + originalIndex + '"]').addClass('active');
            }
        }
    });

    mainContainer.find('.collection-custom-pagination .custom-dot').on('click', function() {
        const targetOriginalIndex = parseInt($(this).data('index'));
        const currentIndex = bannerSwiper.activeIndex;

        let closestSlideIndex = 0;
        let minDiff = Infinity;

        $(bannerSwiper.slides).each(function(index, slide) {
            const slideOriginalIndex = parseInt($(slide).attr('data-original-index'));
            if (!isNaN(slideOriginalIndex) && slideOriginalIndex === targetOriginalIndex) {
                 const diff = Math.abs(index - currentIndex);
                 if (diff < minDiff) {
                     minDiff = diff;
                     closestSlideIndex = index;
                 }
            }
        });

        if(minDiff !== Infinity) {
            bannerSwiper.slideTo(closestSlideIndex);
        }
    });

    syncProducts(bannerSwiper.realIndex);
});
</script>