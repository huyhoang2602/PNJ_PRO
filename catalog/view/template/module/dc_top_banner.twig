<div id="dc-top-banner-wrapper" class="dc-top-banner-wrapper">
    <div id="topBannerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-inner">
            {% for key, banner in banners %}
                <div class="carousel-item {% if key == 0 %}active{% endif %}" style="background-image: url('{{ banner.image }}');">
                    <div class="d-flex align-items-center w-100" style="min-height: 80px;">
                        <div class="container py-3">
                            <div class="row align-items-center">
                                <div class="col-12 text-center text-white banner-content">
                                    {% if banner.title %}
                                        <span class="banner-text fw-bold me-3">{{ banner.title }}</span>
                                    {% endif %}
                                    {% if banner.button %}
                                        <a href="{{ banner.link }}" class="btn banner-btn px-4 shadow-sm">{{ banner.button }}</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    <button type="button" id="close-top-banner" title="Close" aria-label="Close">&times;</button>
</div>

<style>
.dc-top-banner-wrapper {
    position: relative;
    z-index: 1050;
    transition: all 0.3s ease;
    background-color: #f8f9fa;
}
.carousel-item {
    background-size: cover;
    background-position: center;
}

.banner-text {
    font-size: 1.4rem;
    color: #003468;
    text-shadow: none;
    font-family: serif;
    vertical-align: middle;
}
.banner-btn {
    background-color: #9e1c21;
    color: white !important;
    border-radius: 8px;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.9rem;
    padding: 8px 25px;
    transition: all 0.2s ease;
    border: none;
    vertical-align: middle;
}
.banner-btn:hover {
    background-color: #7d161a;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}
#close-top-banner {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.3);
    border: none;
    color: #333;
    font-size: 20px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    line-height: 28px;
    z-index: 1060;
    text-align: center;
    transition: all 0.2s;
}
#close-top-banner:hover {
    background: rgba(255,255,255,0.8);
    color: #000;
}
.carousel-control-prev, .carousel-control-next {
    width: 5%;
    opacity: 0.5;
}
.carousel-control-prev:hover, .carousel-control-next:hover {
    opacity: 1;
}
@media (max-width: 768px) {
    .banner-text {
        font-size: 1rem;
        display: block;
        margin-bottom: 10px;
    }
    .banner-content {
        padding: 0 40px;
    }
    #close-top-banner {
        top: 10px;
        transform: none;
    }
}
</style>

<script type="text/javascript">
$(document).ready(function() {
    $('#close-top-banner').on('click', function() {
        $('#dc-top-banner-wrapper').slideUp(300);
    });
});
</script>
