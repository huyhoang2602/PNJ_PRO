<div id="module-recently-viewed" class="recently-viewed-container mt-4 mb-4">
  {% if products %}
    <h3 class="module-title">{{ heading_title }}</h3>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
      {% for product in products %}
        <div class="col">
          <div class="product-thumb h-100 card shadow-sm">
            <div class="image text-center p-2">
              <a href="{{ product.href }}">
                <img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-fluid" />
              </a>
            </div>
            <div class="content card-body d-flex flex-column justify-content-between text-center">
              <h5 class="card-title mb-2">
                <a href="{{ product.href }}" class="text-decoration-none text-dark">{{ product.name }}</a>
              </h5>
              <div class="price">
                <span class="fw-bold text-danger">{{ product.price }}</span>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>