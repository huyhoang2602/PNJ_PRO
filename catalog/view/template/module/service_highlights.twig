{% if services %}
<section class="dc-service-highlights py-4">
  <div class="container">
    <div class="row text-center">
      {% for service in services %}
        <div class="col-6 col-md-3 mb-3 mb-md-0">
          <div class="dc-service-item d-flex flex-column align-items-center">
            <div class="dc-service-icon mb-2">
              <img src="{{ service.thumb }}" alt="{{ service.title }}" class="img-fluid" loading="lazy">
            </div>
            <h4 class="dc-service-title fw-bold" style="font-size: 0.9rem;">{{ service.title }}</h4>
            <p class="dc-service-desc text-muted mb-0" style="font-size: 0.8rem;">{{ service.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
