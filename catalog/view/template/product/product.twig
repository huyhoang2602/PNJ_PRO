{{ header }}
<div id="product-info" class="container">
	<ul class="breadcrumb">
		{% for breadcrumb in breadcrumbs %}
			<li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
		{% endfor %}
	</ul>
	<div class="row">
		{{ column_left }}
		<div id="content" class="col">

            <script src="extension/dc_minimal/catalog/view/plugins/lightbox/js/lightbox.min.js" type="text/javascript"></script>
            <link href="extension/dc_minimal/catalog/view/plugins/lightbox/css/lightbox.min.css" rel="stylesheet">

			{{ content_top }}
			<div class="row mb-3">
				{% if thumb or images %}
					<div class="col-sm-6">
						<div id="product-gallery" class="mb-4">
                            <div class="position-relative">
                                <a href="{{ popup }}" data-lightbox="product-gallery" id="main-image-link">
                                    <img src="{{ popup }}" alt="{{ heading_title }}" id="main-image" class="img-fluid rounded w-100" />
                                </a>
                                <button class="btn btn-light position-absolute top-50 start-0 translate-middle-y px-2" id="prev-image" style="z-index:1"><i class="fa fa-chevron-left"></i></button>
                                <button class="btn btn-light position-absolute top-50 end-0 translate-middle-y px-2" id="next-image" style="z-index:1"><i class="fa fa-chevron-right"></i></button>
                            </div>

                            {% if images %}
                                <div class="thumbnail-container">
                                    <div class="owl-carousel mt-3" id="thumbnail-carousel">
                                        <div class="item">
                                            <img src="{{ thumb }}" data-full="{{ popup }}" class="img-thumbnail gallery-thumb{% if not images %} active{% endif %}" />
                                        </div>
                                        {% for image in images %}
                                            <div class="item">
                                                <img src="{{ image.thumb }}" data-full="{{ image.popup }}" class="img-thumbnail gallery-thumb" />
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
					</div>
				{% endif %}
				<div class="col-sm-6">
					<h1 class="mb-4">{{ heading_title }}</h1>
					
					<div class="product-metadata mb-4">
						<ul class="list-unstyled">
							{% if manufacturer %}
								<li>{{ text_manufacturer }} <a href="{{ manufacturers }}">{{ manufacturer }}</a></li>
							{% endif %}
							<li>{{ text_model }} <strong>{{ model }}</strong></li>
							{% for product_code in product_codes %}
								<li>{{ product_code.code }}: <strong>{{ product_code.value }}</strong></li>
							{% endfor %}
							{% if reward %}
								<li>{{ text_reward }} {{ reward }}</li>
							{% endif %}
							<li>{{ text_stock }} <span class="badge {% if stock == 'In Stock' %}bg-success{% else %}bg-warning{% endif %} opacity-75">{{ stock }}</span></li>
						</ul>
					</div>

					{% if review_status %}
						<div class="rating mb-4">
							<div class="d-flex align-items-center gap-2">
								<div class="stars text-warning">
									{% for i in 1..5 %}
										{% if rating < i %}
											<i class="fa-regular fa-star"></i>
										{% else %}
											<i class="fa-solid fa-star"></i>
										{% endif %}
									{% endfor %}
								</div>
								<a href="#" class="text-muted small" onclick="$('a[href=\'#tab-review\']').tab('show'); return false;">{{ text_reviews }}</a>
							</div>
						</div>
					{% endif %}

					{% if price %}
						<div class="price-section mb-4 py-3 border-top border-bottom">
							{% if not special %}
								<div class="price-new">{{ price }}</div>
							{% else %}
								<div class="d-flex align-items-baseline gap-2">
									<span class="price-old text-muted">{{ price }}</span>
									<span class="price-new text-primary">{{ special }}</span>
								</div>
							{% endif %}
							{% if tax %}
								<div class="text-tax text-muted small mt-1">{{ text_tax }} {{ tax }}</div>
							{% endif %}
						</div>
					{% endif %}

					<div id="product" class="mb-4">
						<form id="form-product">
							{% if options %}
								<div class="options-wrapper mb-4">
									<h3 class="mb-3">{{ text_option }}</h3>
									{% for option in options %}
										{% if option.type == 'select' %}
											<div class="mb-3{% if option.required %} required{% endif %}">
												<label for="input-option-{{ option.product_option_id }}" class="form-label">{{ option.name }}</label>
												<select name="option[{{ option.product_option_id }}]" id="input-option-{{ option.product_option_id }}" class="form-select rounded-pill">
													<option value="">{{ text_select }}</option>
													{% for option_value in option.product_option_value %}
														<option value="{{ option_value.product_option_value_id }}">{{ option_value.name }}
															{% if option_value.price %}
																({{ option_value.price_prefix }}{{ option_value.price }})
															{% endif %}
														</option>
													{% endfor %}
												</select>
												<div id="error-option-{{ option.product_option_id }}" class="invalid-feedback"></div>
											</div>
										{% endif %}
										{# ... other options ... #}
									{% endfor %}
								</div>
							{% endif %}

							<div class="purchase-section">
                                <div class="row g-3 align-items-center">
                                    <div class="col-auto">
                                        <div class="input-group quantity-selector">
                                            <button type="button" class="btn" id="quantity-minus">−</button>
                                            <input type="text" name="quantity" value="{{ minimum }}" size="2" id="input-quantity" class="form-control text-center shadow-none"/>
                                            <button type="button" class="btn" id="quantity-plus">+</button>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <button type="submit" id="button-cart" class="btn btn-primary w-100">{{ button_cart }}</button>
                                    </div>
									<div class="col-auto">
										<div class="btn-group">
											<button type="button" class="btn btn-light" data-bs-toggle="tooltip" title="{{ button_wishlist }}" onclick="wishlist.add('{{ product_id }}');"><i class="fa-solid fa-heart"></i></button>
											<button type="button" class="btn btn-light" data-bs-toggle="tooltip" title="{{ button_compare }}" onclick="compare.add('{{ product_id }}');"><i class="fa-solid fa-shuffle"></i></button>
										</div>
									</div>
                                </div>
                                <input type="hidden" name="product_id" value="{{ product_id }}" id="input-product-id"/>
                                <div id="error-quantity" class="form-text mt-2 text-danger"></div>
                            </div>
							{% if minimum > 1 %}
								<div class="alert alert-info py-2 mt-3 small"><i class="fa-solid fa-circle-info"></i> {{ text_minimum }}</div>
							{% endif %}
						</form>
					</div>
				</div>
			</div>

			<div class="product-tabs-wrapper mt-5">
				<ul class="nav nav-tabs border-0">
					<li class="nav-item"><a href="#tab-description" data-bs-toggle="tab" class="nav-link active">{{ tab_description }}</a></li>
					{% if attribute_groups %}
						<li class="nav-item"><a href="#tab-specification" data-bs-toggle="tab" class="nav-link">{{ tab_attribute }}</a></li>
					{% endif %}
					{% if review_status %}
						<li class="nav-item"><a href="#tab-review" data-bs-toggle="tab" class="nav-link">{{ tab_review }}</a></li>
					{% endif %}
				</ul>
				<div class="tab-content p-4 bg-white border rounded shadow-sm">
					<div id="tab-description" class="tab-pane fade show active mb-4">
					{{ description }}
					{% if tags %}
						<p>{{ text_tags }}
							{% for tag in tags %}
								<a href="{{ tag.href }}">{{ tag.tag }}</a>{% if not loop.last %},{% endif %}
							{% endfor %}
						</p>
					{% endif %}
				</div>
				{% if attribute_groups %}
					<div id="tab-specification" class="tab-pane fade">
						<div class="table-responsive">
							<table class="table table-bordered">
								{% for attribute_group in attribute_groups %}
									<thead>
										<tr>
											<td colspan="2"><strong>{{ attribute_group.name }}</strong></td>
										</tr>
									</thead>
									<tbody>
										{% for attribute in attribute_group.attribute %}
											<tr>
												<td>{{ attribute.name }}</td>
												<td>{{ attribute.text }}</td>
											</tr>
										{% endfor %}
									</tbody>
								{% endfor %}
							</table>
						</div>
					</div>
				{% endif %}
				{% if review_status %}
					<div id="tab-review" class="tab-pane fade mb-4">
						{{ review }}
					</div>
				{% endif %}
			</div>
			{{ related }}
			{{ content_bottom }}
		</div>
		{{ column_right }}
	</div>
</div>
<script>
    $(document).ready(function () {

        $('#quantity-minus').on('click', function(){
            let $qty = $('#input-quantity');
            let val = parseInt($qty.val(), 10) || 1;
            if(val > 1) $qty.val(val - 1);
        });
        $('#quantity-plus').on('click', function(){
            let $qty = $('#input-quantity');
            let val = parseInt($qty.val(), 10) || 1;
            $qty.val(val + 1);
        });

        var currentIndex = 0;
        var images = [
            { thumb: '{{ thumb }}', popup: '{{ popup }}' },
            {% for image in images %}
                { thumb: '{{ image.thumb }}', popup: '{{ image.popup }}' },
            {% endfor %}
        ];

        function showImage(index) {
            const image = images[index];
            $('#main-image').attr('src', image.popup);
            $('#main-image-link').attr('href', image.popup);
            currentIndex = index;
        }

        $('#prev-image').on('click', function () {
            if (currentIndex > 0) showImage(currentIndex - 1);
        });

        $('#next-image').on('click', function () {
            if (currentIndex < images.length - 1) showImage(currentIndex + 1);
        });

        $(document).on('click', '.gallery-thumb', function () {
            const src = $(this).attr('data-full');
            const index = images.findIndex(img => img.popup === src);
            if (index !== -1) showImage(index);
        });

        $('#thumbnail-carousel').owlCarousel({
            margin: 10,
            nav: true,
            dots: false,
            navText: ['<i class="fa fa-chevron-left"></i>', '<i class="fa fa-chevron-right"></i>'],
            responsive: {
            0: { items: 3 },
            768: { items: 5 }
            }
        });
    });

    $('#input-subscription').on('change', function(e) {
        var element = this;

        $('.subscription').addClass('d-none');

        $('#subscription-description-' + $(element).val()).removeClass('d-none');
    });

    $('#form-product').on('submit', function(e) {
        e.preventDefault();

        $.ajax({
            url: 'index.php?route=checkout/cart.add&language={{ language }}',
            type: 'post',
            data: $('#form-product').serialize(),
            dataType: 'json',
            contentType: 'application/x-www-form-urlencoded',
            cache: false,
            processData: false,
            beforeSend: function() {
                $('#button-cart').button('loading');
            },
            complete: function() {
                $('#button-cart').button('reset');
            },
            success: function(json) {
                console.log(json);

                $('#form-product').find('.is-invalid').removeClass('is-invalid');
                $('#form-product').find('.invalid-feedback').removeClass('d-block');

                if (json['error']) {
                    for (key in json['error']) {
                        $('#input-' + key.replaceAll('_', '-')).addClass('is-invalid').find('.form-control, .form-select, .form-check-input, .form-check-label').addClass('is-invalid');
                        $('#error-' + key.replaceAll('_', '-')).html(json['error'][key]).addClass('d-block');
                    }
                }

                if (json['success']) {
                    showModalMessage('success', json['success']);
                    $('#cart').load('index.php?route=common/cart.info&language={{ language }}', function(){
                        setTimeout(openCart, 300);
                        setTimeout(updateCartCount, 300);
                    });
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            }
        });
    });


</script>
{{ footer }}