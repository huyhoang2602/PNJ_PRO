{{ header }}
<div id="product-search" class="container">
	<ul class="breadcrumb">
		{% for breadcrumb in breadcrumbs %}
			<li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
		{% endfor %}
	</ul>
	<div class="row">
		{{ column_left }}
		<div id="content" class="col">
			{{ content_top }}
			<div class="category-banner-pnj mb-4">
                <div class="banner-content">
                    <div class="banner-text text-center">
                        <h1 class="pnj-title">{{ heading_title }}</h1>
                    </div>
                </div>
            </div>

			{% if products %}
				<div class="listing-interface">
                    <div id="display-control" class="row align-items-center g-3">
                        <div class="col-12 col-xl-auto d-flex align-items-center flex-nowrap gap-2 overflow-auto mb-2 mb-xl-0" style="scrollbar-width: none; -ms-overflow-style: none;">
                            <div class="horizontal-filters-wrapper d-flex align-items-center flex-nowrap gap-2">
                                {% for group in dynamic_filters %}
                                    <div class="dropdown filter-dropdown">
                                        <button class="btn btn-outline-filter dropdown-toggle" type="button" id="dropdownFilter{{ loop.index }}" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside" data-bs-popper-config='{"strategy":"fixed"}'>
                                            {{ group.label }} <span class="selected-count badge bg-primary rounded-pill ms-1 d-none">0</span>
                                        </button>
                                        <div class="dropdown-menu p-3 shadow-lg border-0" aria-labelledby="dropdownFilter{{ loop.index }}" style="min-width: 250px; border-radius: 12px;">
                                            {% if group.type == 'price' %}
                                                <div class="price-filter-container">
                                                    <div class="d-flex align-items-center gap-2 mb-2">
                                                        <div class="flex-grow-1">
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text bg-light border-0">{{ text_from }}</span>
                                                                <input type="number" class="form-control border-0 bg-light" name="price_min" placeholder="{{ text_currency_hint_pnj }}" value="{{ price_min ? price_min : '' }}">
                                                            </div>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text bg-light border-0">{{ text_to }}</span>
                                                                <input type="number" class="form-control border-0 bg-light" name="price_max" placeholder="{{ text_currency_hint_pnj }}" value="{{ price_max ? price_max : '' }}">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            {% else %}
                                                <div class="filter-options-scroll custom-scrollbar" style="max-height: 300px; overflow-y: auto;">
                                                    {% for val in group.values %}
                                                        <div class="form-check custom-check mb-2">
                                                            {% if group.type == 'manufacturer' %}
                                                                <input type="checkbox" class="form-check-input" name="manufacturer_id[]" value="{{ val.id }}" id="h-filter-m-{{ val.id }}" {% if val.id in manufacturer_ids %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-m-{{ val.id }}">
                                                                    {{ val.name }} {% if val.count is defined %}<span class="text-muted">({{ val.count }})</span>{% endif %}
                                                                </label>
                                                            {% elseif group.type == 'category' %}
                                                                <input type="checkbox" class="form-check-input" name="sub_cat[]" value="{{ val.id }}" id="h-filter-c-{{ val.id }}" {% if val.id in category_ids %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-c-{{ val.id }}">
                                                                    {{ val.name }} {% if val.count is defined %}<span class="text-muted">({{ val.count }})</span>{% endif %}
                                                                </label>
                                                            {% elseif group.type == 'attribute' %}
                                                                <input type="checkbox" class="form-check-input" name="attr[{{ group.source_id }}][]" value="{{ val.id }}" id="h-filter-a-{{ group.source_id }}-{{ loop.index }}" {% if val.id in attr[group.source_id] %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-a-{{ group.source_id }}-{{ loop.index }}">
                                                                    {{ val.name }} {% if val.count is defined %}<span class="text-muted">({{ val.count }})</span>{% endif %}
                                                                </label>
                                                            {% elseif group.type == 'option' %}
                                                                <input type="checkbox" class="form-check-input" name="opt[]" value="{{ val.id }}" id="h-filter-o-{{ val.id }}" {% if val.id in opt %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-o-{{ val.id }}">
                                                                    {{ val.name }} {% if val.count is defined %}<span class="text-muted">({{ val.count }})</span>{% endif %}
                                                                </label>
                                                            {% elseif group.type == 'filter' %}
                                                                <input type="checkbox" class="form-check-input" name="filter[]" value="{{ val.id }}" id="h-filter-f-{{ val.id }}" {% if val.id in filter_ids %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-f-{{ val.id }}">
                                                                    {{ val.name }} {% if val.count is defined %}<span class="text-muted">({{ val.count }})</span>{% endif %}
                                                                </label>
                                                            {% elseif group.type == 'stock' %}
                                                                <input type="radio" class="form-check-input" name="stock" value="{{ val.id }}" id="h-filter-s-{{ val.id }}" {% if val.id == stock %}checked{% endif %}>
                                                                <label class="form-check-label" for="h-filter-s-{{ val.id }}">
                                                                    {{ val.name }}
                                                                </label>
                                                            {% endif %}
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            {% endif %}
                                            <div class="dropdown-divider"></div>
                                            <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                                                <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 text-muted dropdown-clear" style="font-size: 11px;">{{ text_clear }}</button>
                                                <button type="button" class="btn btn-primary btn-sm px-3 dropdown-apply" style="font-size: 12px; border-radius: 50px;">{{ text_apply }}</button>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                                <button type="button" id="button-clear-all" class="btn btn-link btn-sm text-muted text-decoration-none d-none" style="font-size: 12px;">{{ text_clear_all }}</button>
                            </div>
                        </div>
                        
                        <div class="col-12 col-xl-auto ms-xl-auto d-flex flex-column align-items-end gap-1">
                            <div class="d-flex align-items-center gap-2">
                                <div class="dropdown filter-dropdown">
                                    <button class="btn btn-outline-filter dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <span class="text-muted fw-400" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">{{ text_sort|replace({':': ''}) }}</span> 
                                        <span class="ms-1">
                                            {% for sorts in sorts %}
                                                {% if sorts.value == '%s-%s'|format(sort, order) %}{{ sorts.text }}{% endif %}
                                            {% endfor %}
                                        </span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-2" style="border-radius:12px; min-width: 180px;">
                                        {% for sorts in sorts %}
                                            <li><a class="dropdown-item {% if sorts.value == '%s-%s'|format(sort, order) %}active{% endif %}" href="{{ sorts.href }}" style="font-size:12px; padding: 8px 15px;">{{ sorts.text }}</a></li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                
                                <div class="dropdown filter-dropdown">
                                    <button class="btn btn-outline-filter dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <span class="text-muted fw-400" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">{{ text_limit|replace({':': ''}) }}</span>
                                        <span class="ms-1">
                                            {% for limits in limits %}
                                                {% if limits.value == limit %}{{ limits.text }}{% endif %}
                                            {% endfor %}
                                        </span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-2" style="border-radius:12px; min-width: 80px;">
                                        {% for limits in limits %}
                                            <li><a class="dropdown-item {% if limits.value == limit %}active{% endif %}" href="{{ limits.href }}" style="font-size:12px; padding: 8px 15px; text-align: center;">{{ limits.text }}</a></li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                            <span class="results-info-pnj text-muted" style="font-size: 11px; font-weight: 500; opacity: 0.7;">{{ results }}</span>
                        </div>
                    </div>
                </div>
				<div id="product-list" class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-4">
					{% for product in products %}
						<div class="col mb-3">{{ product }}</div>
					{% endfor %}
				</div>
				<div class="row" id="pagination-wrapper">
					<div class="col-sm-6 text-start">{{ pagination }}</div>
					<div class="col-sm-6 text-end">{{ results }}</div>
				</div>
			{% else %}
				<p>{{ text_no_results }}</p>
				<div class="text-end"><a href="{{ continue }}" class="btn btn-primary">{{ button_continue }}</a></div>
			{% endif %}
			{{ content_bottom }}
		</div>
		{{ column_right }}
	</div>
</div>

<script type="text/javascript"><!--
function applyFilters() {
    let url = 'index.php?route=product/special&language={{ language }}';
    
    // Helper function for building the URL
    function addParam(name, value) {
        url += '&' + name + '=' + value;
    }

    // 1. Manufacturers
    let manufacturers = [];
    $('.listing-interface input[name^=\'manufacturer_id\']:checked').each(function() {
        manufacturers.push(this.value);
    });
    if (manufacturers.length > 0) addParam('manufacturer_id', manufacturers.join(','));

    // 2. Categories
    let subcats = [];
    $('.listing-interface input[name^=\'sub_cat\']:checked').each(function() {
        subcats.push(this.value);
    });
    if (subcats.length > 0) addParam('sub_cat', subcats.join(','));

    // 3. Attributes
    $('.listing-interface input[name^=\'attr\']:checked').each(function() {
        addParam($(this).attr('name'), encodeURIComponent(this.value));
    });

    // 4. Options
    let options = [];
    $('.listing-interface input[name^=\'opt\']:checked').each(function() {
        options.push(this.value);
    });
    if (options.length > 0) addParam('opt', options.join(','));

    // 5. Price Range
    let price_min = $('.listing-interface input[name=\'price_min\']').val();
    let price_max = $('.listing-interface input[name=\'price_max\']').val();
    if (price_min) addParam('price_min', price_min);
    if (price_max) addParam('price_max', price_max);

    // 6. Stock
    let stock = $('.listing-interface input[name=\'stock\']:checked').val();
    if (stock) addParam('stock', stock);

    // AJAX Request
    let ajaxUrl = url + (url.indexOf('?') !== -1 ? '&' : '?') + 'ajax=1';
    
    $.ajax({
        url: ajaxUrl,
        type: 'get',
        beforeSend: function() {
            $('#product-list').css('opacity', 0.5);
            $('.dropdown-apply').prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
        },
        success: function(html) {
            let response = $('<div>').append($.parseHTML(html));
            $('#product-list').html(response.find('#product-list').html() || $(html).find('#product-list').html()).css('opacity', 1);
            $('.listing-interface').html(response.find('.listing-interface').html() || $(html).find('.listing-interface').html());
            $('#pagination-wrapper').html(response.find('#pagination-wrapper').html() || $(html).find('#pagination-wrapper').html());
            window.history.pushState({}, '', url);
            $('.filter-dropdown .dropdown-toggle').dropdown('hide');
            updateFilterUI();
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.error(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
            $('#product-list').css('opacity', 1);
        },
        complete: function() {
            $('.dropdown-apply').prop('disabled', false).text('{{ text_apply|escape('js') }}');
        }
    });
}

function updateFilterUI() {
    let hasAnyFilter = false;
    $('.filter-dropdown').each(function() {
        let count = $(this).find('input:checked').length;
        if ($(this).find('input[name="price_min"]').val() || $(this).find('input[name="price_max"]').val()) {
            count = 1;
        }
        
        let badge = $(this).find('.selected-count');
        if (count > 0) {
            badge.text(count).removeClass('d-none');
            $(this).find('.btn-outline-filter').addClass('active');
            hasAnyFilter = true;
        } else {
            badge.addClass('d-none');
            $(this).find('.btn-outline-filter').removeClass('active');
        }
    });
    
    if (hasAnyFilter) {
        $('#button-clear-all').removeClass('d-none');
    } else {
        $('#button-clear-all').addClass('d-none');
    }
}

// Dropdown Actions
$(document).on('click', '.dropdown-apply', function(e) {
    e.preventDefault();
    applyFilters();
});

$(document).on('click', '.dropdown-clear', function(e) {
    e.preventDefault();
    $(this).closest('.dropdown-menu').find('input[type="checkbox"], input[type="radio"]').prop('checked', false);
    $(this).closest('.dropdown-menu').find('input[type="number"], input[type="text"]').val('');
    applyFilters();
});

$(document).on('click', '#button-clear-all', function(e) {
    e.preventDefault();
    $('.listing-interface input[type="checkbox"], .listing-interface input[type="radio"]').prop('checked', false);
    $('.listing-interface input[type="number"], .listing-interface input[type="text"]').val('');
    applyFilters();
});

// AJAX Pagination
$(document).on('click', '#pagination-wrapper a', function(e) {
    e.preventDefault();
    let url = $(this).attr('href');
    let ajaxUrl = url + (url.indexOf('?') !== -1 ? '&' : '?') + 'ajax=1';
    
    $.ajax({
        url: ajaxUrl,
        type: 'get',
        beforeSend: function() {
            $('#product-list').css('opacity', 0.5);
            $('html, body').animate({ scrollTop: $('#product-list').offset().top - 100 }, 'slow');
        },
        success: function(html) {
            let response = $('<div>').append($.parseHTML(html));
            $('#product-list').html(response.find('#product-list').html()).css('opacity', 1);
            $('.listing-interface').html(response.find('.listing-interface').html());
            $('#pagination-wrapper').html(response.find('#pagination-wrapper').html());
            window.history.pushState({}, '', url);
            updateFilterUI();
        }
    });
});

$(document).ready(function() {
    updateFilterUI();
});
//--></script>
			{{ content_bottom }}
		</div>
		{{ column_right }}
	</div>
</div>
{{ footer }}
