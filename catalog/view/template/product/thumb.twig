<div class="dc-product-card">
  <div class="dc-product-image">
    <a href="{{ href }}">
      <img src="{{ thumb }}" alt="{{ name }}" title="{{ name }}" class="img-fluid" loading="lazy" />
    </a>
    
    {% if special %}
      <div class="dc-badge dc-badge-sale">Sale</div>
    {% endif %}
    
    <div class="dc-badge-installment">
        <span class="ins-num">0%</span>
        <span class="ins-txt">Trả góp</span>
    </div>

    <div class="dc-product-actions">
      <button type="button" onclick="wishlist.add('{{ product_id }}');" class="dc-btn-action" title="{{ button_wishlist }}"><i class="fa-regular fa-heart"></i></button>
      <button type="button" onclick="compare.add('{{ product_id }}');" class="dc-btn-action" title="{{ button_compare }}"><i class="fa-solid fa-arrows-rotate"></i></button>
    </div>
  </div>

  <div class="dc-product-info">
    <div class="dc-product-brand">
        {% if manufacturer %}
            <a href="#">{{ manufacturer }}</a>
        {% else %}
            &nbsp;
        {% endif %}
    </div>
    
    <h4 class="dc-product-name">
      <a href="{{ href }}" class="stretched-link">{{ name }}</a>
    </h4>

    <div class="dc-product-price">
      {% if price %}
        {% if not special %}
          <span class="price-new">{{ price }}</span>
        {% else %}
          <span class="price-new">{{ special }}</span>
          <div class="price-meta">
             <span class="dc-price-old">{{ price }}</span>
          </div>
        {% endif %}
      {% endif %}
    </div>

    <div class="dc-product-footer">
        <div class="dc-rating">
            <span class="rating-stars">
                {% for i in 1..5 %}
                <i class="fa{% if rating >= i %}-solid{% else %}-regular{% endif %} fa-star"></i>
                {% endfor %}
            </span>
            <span class="rating-count">({{ rating }})</span>
        </div>
        <div class="dc-sold-count">
            {{ (product_id * 7 + 100) }} đã bán
        </div>
    </div>
  </div>
</div>