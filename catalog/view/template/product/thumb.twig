<div class="product-thumb transition text-center">
    <div class="image">
        <a href="{{ href }}"><img src="{{ thumb }}" alt="{{ name }}" title="{{ name }}" class="img-responsive" /></a>
    </div>

    <div class="caption">
        <h4><a href="{{ href }}">{{ name }}</a></h4>
        {% if rating %}
            <div class="rating">
                {% for i in 1..5 %}
                    {% if rating < i %}
                        <span class="fa fa-stack"><i class="fa fa-star-o fa-stack-2x"></i></span>
                    {% else %}
                        <span class="fa fa-stack"><i class="fa fa-star fa-stack-2x"></i><i class="fa fa-star-o fa-stack-2x"></i></span>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}

        {% if price %}
            <p class="price">
                {% if not special %}
                    {{ price }}
                {% else %}
                    <span class="price-new">{{ special }}</span> <span class="price-old">{{ price }}</span>
                {% endif %}
            </p>
        {% endif %}
    </div>
    <form method="post" data-oc-toggle="ajax" data-oc-load="{{ cart }}" data-oc-target="#cart">
        <div class="button-group">
            <button type="submit" formaction="{{ cart_add }}" class="btn-listing"><i class="fa fa-shopping-cart"></i></button>
            <button type="submit" formaction="{{ wishlist_add }}" class="btn-listing"><i class="fa fa-heart"></i></button>
            <button type="submit" formaction="{{ compare_add }}" class="btn-listing"><i class="fa fa-exchange"></i></button>
        </div>

        <input type="hidden" name="product_id" value="{{ product_id }}"/> <input type="hidden" name="quantity" value="{{ minimum }}"/>
    </form>
</div>